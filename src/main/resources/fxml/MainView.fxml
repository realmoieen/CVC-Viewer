<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Menu?>
<?import javafx.scene.control.MenuBar?>
<?import javafx.scene.control.MenuItem?>
<?import javafx.scene.control.Tab?>
<?import javafx.scene.control.TabPane?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>

<BorderPane xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="io.github.realmoieen.cvcviewer.ui.main.MainController">
    <top>
        <MenuBar>
            <menus>
                <Menu text="File">
                    <items>
                        <MenuItem fx:id="openMenuItem" mnemonicParsing="true" text="_Open"/>
                        <MenuItem fx:id="saveAsMenuItem" mnemonicParsing="true" text="_Save As"/>
                    </items>
                </Menu>
                <Menu text="Help">
                    <items>
                        <MenuItem fx:id="aboutMenuItem" mnemonicParsing="true" text="_About"/>
                    </items>
                </Menu>
            </menus>
        </MenuBar>
    </top>
    <center>
        <TabPane tabClosingPolicy="UNAVAILABLE">
            <tabs>
                <Tab text="General">
                    <content>
                        <fx:include fx:id="generalView" source="GeneralView.fxml"/>
                    </content>
                </Tab>
                <Tab text="Details">
                    <content>
                        <fx:include fx:id="detailView" source="DetailView.fxml"/>
                    </content>
                </Tab>
                <Tab text="Path">
                    <content>
                        <fx:include fx:id="pathView" source="PathView.fxml"/>
                    </content>
                </Tab>
            </tabs>
        </TabPane>
    </center>
    <bottom>
        <HBox alignment="CENTER_RIGHT" spacing="10.0" BorderPane.alignment="CENTER">
            <padding>
                <Insets bottom="10.0" left="10.0" right="10.0" top="10.0"/>
            </padding>
            <Button onAction="#onCopyToFile" text="Copy To File..."/>
            <Button onAction="#onOk" text="OK"/>
        </HBox>
    </bottom>
</BorderPane>
